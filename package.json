{
  "name": "snapscript-monorepo",
  "version": "0.4.0",
  "description": "SnapScript workspace.",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "scripts": {
    "bench": "vitest run test/benchmark.test.ts test/benchmark-examples.test.ts test/benchmark-memory.test.ts --reporter=verbose",
    "build": "pnpm --filter snapscript build && pnpm --filter snapscript-cli build && pnpm --filter create-snapscript build",
    "example:ecs:build": "pnpm --dir examples/ecs build",
    "example:ecs:dev": "pnpm --dir examples/ecs dev",
    "example:protocol:build": "pnpm build && pnpm --dir examples/protocol build",
    "example:protocol:generate": "pnpm build && pnpm --dir examples/protocol generate",
    "example:simple:build": "pnpm --dir examples/simple build",
    "example:simple:dev": "pnpm --dir examples/simple dev",
    "test:examples": "pnpm example:protocol:build && pnpm example:simple:build && pnpm example:ecs:build",
    "test": "vitest run",
    "pack:dry-run": "node scripts/release-check.mjs --pack-only",
    "release:check": "node scripts/release-check.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tinybench": "2.9.0",
    "tsdown": "^0.16.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1"
    }
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
