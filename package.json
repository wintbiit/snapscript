{
  "name": "snapscript",
  "version": "0.0.0",
  "description": "Platform-agnostic TypeScript network synchronization framework.",
  "license": "GPL-3.0-only",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "bench": "vitest run test/benchmark.test.ts test/benchmark-examples.test.ts test/benchmark-memory.test.ts --reporter=verbose",
    "bench:branch:compare": "node ./scripts/bench-branch-compare.mjs",
    "bench:memory:compare": "node ./scripts/bench-memory-compare.mjs",
    "build": "tsdown",
    "example:ecs:build": "pnpm --dir examples/ecs build",
    "example:ecs:dev": "pnpm --dir examples/ecs dev",
    "example:simple:build": "pnpm --dir examples/simple build",
    "example:simple:dev": "pnpm --dir examples/simple dev",
    "test:examples": "pnpm example:simple:build && pnpm example:ecs:build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tinybench": "2.9.0",
    "tsdown": "^0.16.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
