{
  "name": "snapscript-cli",
  "version": "0.3.0",
  "description": "SnapScript project and protocol generation CLI.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wintbiit/snapscript.git",
    "directory": "packages/snapscript-cli"
  },
  "homepage": "https://github.com/wintbiit/snapscript#readme",
  "bugs": {
    "url": "https://github.com/wintbiit/snapscript/issues"
  },
  "keywords": [
    "snapscript",
    "cli",
    "idl",
    "codegen",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "snapscript": "./dist/cli.mjs"
  },
  "exports": {
    "./project": {
      "types": "./dist/project.d.mts",
      "import": "./dist/project.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "eta": "^4.6.0",
    "peggy": "^5.1.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "snapscript": "^0.3.0"
  }
}
