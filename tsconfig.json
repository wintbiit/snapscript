{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "useDefineForClassFields": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "paths": {
      "snapscript": ["./packages/snapscript/src/index.ts"],
      "snapscript-cli": ["./packages/snapscript-cli/src/cli.ts"],
      "snapscript-cli/project": ["./packages/snapscript-cli/src/project.ts"]
    }
  },
  "include": ["packages", "test", "vitest.config.ts"]
}
